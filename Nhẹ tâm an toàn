using namespace std;

struct Vector3 {
    float x, y, z;
    Vector3() : x(0), y(0), z(0) {}
    Vector3(float x, float y, float z) : x(x), y(y), z(z) {}
    float Distance(const Vector3& other) {
        return sqrtf(powf(x - other.x, 2) + powf(y - other.y, 2) + powf(z - other.z, 2));
    }
};

struct Player {
    Vector3 head;
    Vector3 position;
    float health;
    bool alive;
    bool enemy;
};

vector<Player> players;
Vector3 localPlayerPos;
bool aimlockEnabled = true;
bool noRecoilEnabled = true;
float aimFov = 30.0f;
float smoothFactor = 0.5f;

float CalcYaw(const Vector3& from, const Vector3& to) {
    float dx = to.x - from.x;
    float dy = to.y - from.y;
    float dz = to.z - from.z;
    return atan2f(dy, dx) * 180.0f / 3.14159265f;
}

float CalcPitch(const Vector3& from, const Vector3& to) {
    float dx = to.x - from.x;
    float dy = to.y - from.y;
    float dz = to.z - from.z;
    float hyp = sqrtf(dx*dx + dz*dz);
    return -atan2f(dy, hyp) * 180.0f / 3.14159265f;
}

Player GetBestTarget() {
    Player best;
    float bestScore = 9999.0f;
    for (auto& p : players) {
        if (!p.alive || !p.enemy) continue;
        float dist = localPlayerPos.Distance(p.position);
        float yaw = CalcYaw(localPlayerPos, p.head);
        float score = yaw + (dist / 1000.0f);
        if (score < bestScore) {
            bestScore = score;
            best = p;
        }
    }
    return best;
}

